# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tip
DATABASE_URL=postgresql+asyncpg://postgres:postgres@tip-postgres:5432/tip

# Redis
REDIS_URL=redis://tip-redis:6379/0

# Celery
CELERY_BROKER_URL=redis://tip-redis:6379/0
